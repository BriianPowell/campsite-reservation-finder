<html>
<body>
  <h2>{{ search_name }}</h2>

  <p>
    <strong>{{ new_match_count }}</strong> new matching {{ "campsite" if new_match_count == 1 else "campsites" }} found.<br>
    <strong>{{ total_matches }}</strong> total matching {{ "campsite" if total_matches == 1 else "campsites" }} currently available.
  </p>

  {% for campground in campgrounds %}
  <h3>{{ campground.name }}</h3>
  <table border="1" cellpadding="6" cellspacing="0">
    <thead>
      <tr>
        <th>Dates</th>
        <th>Site</th>
        <th>Type</th>
        <th>Use</th>
        <th>Occupancy</th>
        <th>Equipment</th>
      </tr>
    </thead>
    <tbody>
      {% for campsite in campground.campsites %}
      <tr>
        <td>
          {% for date in campsite.dates %}
          {% if date.booking_url %}<a href="{{ date.booking_url }}">{{ date.label }}</a>{% else %}{{ date.label }}{% endif %}{% if not loop.last %}<br>{% endif %}
          {% endfor %}
        </td>
        <td>{{ campsite.site }}</td>
        <td>{{ campsite.type }}</td>
        <td>{{ campsite.use }}</td>
        <td>{{ campsite.occupancy }}</td>
        <td>{% for equipment in campsite.equipment %}{{ equipment }}{% if not loop.last %}<br>{% endif %}{% endfor %}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endfor %}

  <p><em>camply, the campsite finder</em></p>
</body>
</html>
